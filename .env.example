# ===========================================
# OpenClaw Gateway + PostgreSQL Configuration
# OpenClaw Gateway + PostgreSQL 設定檔
# ===========================================
# Copy this file to .env and fill in the values
# 複製此檔案為 .env 並填入數值
# ===========================================

# -----------------------
# PostgreSQL Database
# PostgreSQL 資料庫
# -----------------------
POSTGRES_DB=openclaw
POSTGRES_USER=openclaw
# IMPORTANT: Change this to a secure password!
# 重要：請修改為安全的密碼！
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# -----------------------
# OpenClaw Gateway
# OpenClaw Gateway 設定
# -----------------------
# Image version tag / 映像版本標籤
OPENCLAW_VERSION=latest

# Port exposed on host (gateway API)
# 主機開放的連接埠（Gateway API）
GATEWAY_PORT=18789

# -----------------------
# Setup Wizard
# 設定精靈
# -----------------------
# Port for the provisioning web UI
# 設定精靈的連接埠
WIZARD_PORT=18790

# -----------------------
# Cloudflare Tunnel Settings
# Cloudflare Tunnel 設定
# -----------------------
# Cloudflare API Token (with tunnel permissions)
# Cloudflare API Token（需 tunnel 權限）
CF_API_TOKEN=

# Cloudflare Account ID / Cloudflare 帳戶 ID
CF_ACCOUNT_ID=

# Tunnel ID (obtained after tunnel creation)
# Tunnel ID（建立 tunnel 後取得）
CF_TUNNEL_ID=

# Tunnel token (obtained after tunnel creation)
# Tunnel token（建立 tunnel 後取得）
CF_TUNNEL_TOKEN=

# Domain for the tunnel / Tunnel 網域
CF_TUNNEL_DOMAIN=woowtech-openclaw.woowtech.io

# -----------------------
# AI Providers (choose at least one)
# AI 供應商（至少選擇一個）
# -----------------------
# OpenAI (GPT-4o, o1, GPT-4 Turbo)
# OPENAI_API_KEY=sk-proj-your-key

# Anthropic (Claude Sonnet/Opus/Haiku)
# ANTHROPIC_API_KEY=sk-ant-api03-your-key

# Google Gemini (Gemini 2.0 Flash, 2.5 Pro)
# GOOGLE_API_KEY=AIzaSy-your-key

# MiniMax (M2.5, Text-01)
# MINIMAX_API_KEY=your-minimax-key

# DeepSeek (Chat, Coder, Reasoner)
# DEEPSEEK_API_KEY=sk-your-deepseek-key

# Qwen / 通義千問 (Max, Plus, Turbo)
# QWEN_API_KEY=sk-your-qwen-key

# OpenRouter (100+ models via single key)
# OPENROUTER_API_KEY=sk-or-v1-your-key

# Ollama (local models — set host URL)
# OLLAMA_HOST=http://host.containers.internal:11434

# -----------------------
# Chat Channels (optional — configure in Control UI)
# 聊天頻道（選填 — 在管理介面設定）
# -----------------------
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# WHATSAPP_ENABLED=true
