############
# OpenClaw K3s PaaS — Environment Variables
# Copy to .env and fill in your values
# 複製為 .env 並填入你的值
############

############
# Cloudflare Tunnel
# Get these by running: python3 init-cloudflare.py
# 執行 init-cloudflare.py 取得以下值
############
CF_API_TOKEN=your-cloudflare-api-token
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_TUNNEL_ID=your-tunnel-id
CF_TUNNEL_TOKEN=your-tunnel-token
DOMAIN=your-domain.example.com
TUNNEL_NAME=openclaw

############
# OpenClaw Gateway
# Gateway credentials — set during setup wizard
# Gateway 認證 — 在 setup wizard 設定
############
GATEWAY_TOKEN=your-gateway-token
DB_PASSWORD=your-database-password

############
# AI Providers (choose at least one)
# AI 供應商（至少選擇一個）
############
# OpenAI (GPT-4o, o1, GPT-4 Turbo)
OPENAI_API_KEY=sk-proj-your-openai-key

# Anthropic (Claude Sonnet/Opus/Haiku)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google Gemini (Gemini 2.0 Flash, 2.5 Pro)
# GEMINI_API_KEY=AIzaSy-your-gemini-key

# MiniMax (M2.5, Text-01)
# MINIMAX_API_KEY=your-minimax-key

# DeepSeek (Chat, Coder, Reasoner)
# DEEPSEEK_API_KEY=sk-your-deepseek-key

# Qwen / 通義千問 (Max, Plus, Turbo)
# QWEN_API_KEY=sk-your-qwen-key

# OpenRouter (100+ models via single key)
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Ollama (local models — set host URL)
# OLLAMA_HOST=http://localhost:11434

############
# Chat Channels (optional — configure in Control UI)
# 聊天頻道（選填 — 在管理介面設定）
############
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# WHATSAPP_ENABLED=true
