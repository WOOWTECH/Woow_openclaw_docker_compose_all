# ===========================================
# OpenClaw Gateway + PostgreSQL Configuration
# OpenClaw Gateway + PostgreSQL 設定檔
# ===========================================
# Copy this file to .env and fill in the values
# 複製此檔案為 .env 並填入數值
# ===========================================

# -----------------------
# PostgreSQL Database
# PostgreSQL 資料庫
# -----------------------
POSTGRES_DB=openclaw
POSTGRES_USER=openclaw
# IMPORTANT: Change this to a secure password!
# 重要：請修改為安全的密碼！
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# -----------------------
# OpenClaw Gateway
# OpenClaw Gateway 設定
# -----------------------
# Image version tag / 映像版本標籤
OPENCLAW_VERSION=latest

# Port exposed on host (gateway API)
# 主機開放的連接埠（Gateway API）
GATEWAY_PORT=18789

# -----------------------
# Setup Wizard
# 設定精靈
# -----------------------
# Port for the provisioning web UI
# 設定精靈的連接埠
WIZARD_PORT=18790

# -----------------------
# Cloudflare Tunnel Settings
# Cloudflare Tunnel 設定
# -----------------------
# Cloudflare API Token (with tunnel permissions)
# Cloudflare API Token（需 tunnel 權限）
CF_API_TOKEN=

# Cloudflare Account ID / Cloudflare 帳戶 ID
CF_ACCOUNT_ID=

# Tunnel ID (obtained after tunnel creation)
# Tunnel ID（建立 tunnel 後取得）
CF_TUNNEL_ID=

# Tunnel token (obtained after tunnel creation)
# Tunnel token（建立 tunnel 後取得）
CF_TUNNEL_TOKEN=

# Domain for the tunnel / Tunnel 網域
CF_TUNNEL_DOMAIN=woowtech-openclaw.woowtech.io
