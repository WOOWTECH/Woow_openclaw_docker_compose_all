# =============================================================
# Paperclip AI — Build from source
#
# Build:
#   git clone --depth 1 https://github.com/paperclipai/paperclip.git /tmp/paperclip-src
#   sudo buildah bud -t paperclip:latest -f Dockerfile.paperclip /tmp/paperclip-src
#
# Import to k3s:
#   sudo buildah push paperclip:latest docker-archive:/tmp/paperclip.tar:paperclip:latest
#   sudo k3s ctr images import /tmp/paperclip.tar
# =============================================================

# ── Stage 1: Install dependencies ─────────────────────────────
FROM node:lts-trixie-slim AS deps

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl git python3 make g++ \
    && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json apps/web/
COPY apps/desktop/package.json apps/desktop/
COPY cli/package.json cli/
COPY packages/adapters/claude-local/package.json packages/adapters/claude-local/
COPY packages/adapters/codex-local/package.json packages/adapters/codex-local/
COPY packages/adapters/cursor-local/package.json packages/adapters/cursor-local/
COPY packages/adapters/gemini-local/package.json packages/adapters/gemini-local/
COPY packages/adapters/openclaw-gateway/package.json packages/adapters/openclaw-gateway/
COPY packages/adapters/opencode-local/package.json packages/adapters/opencode-local/
COPY packages/adapters/pi-local/package.json packages/adapters/pi-local/
COPY packages/adapter-utils/package.json packages/adapter-utils/
COPY packages/core/package.json packages/core/
COPY packages/db/package.json packages/db/
COPY packages/mcp-server/package.json packages/mcp-server/
COPY packages/plugins/sdk/package.json packages/plugins/sdk/
COPY packages/shared/package.json packages/shared/
COPY packages/ui/package.json packages/ui/
COPY packages/views/package.json packages/views/
COPY server/package.json server/

RUN pnpm install --frozen-lockfile

# ── Stage 2: Build ─────────────────────────────────────────────
FROM deps AS build
COPY . .
RUN pnpm --filter @paperclipai/ui build \
    && pnpm --filter @paperclipai/views build \
    && pnpm --filter @paperclipai/web build \
    && pnpm --filter @paperclipai/plugin-sdk build \
    && pnpm --filter @paperclipai/server build

# ── Stage 3: Production image ─────────────────────────────────
FROM node:lts-trixie-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl git openssh-client jq \
    && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@latest --activate

# Create paperclip user
RUN groupadd --gid 1000 node 2>/dev/null || true \
    && useradd --uid 1000 --gid 1000 --create-home node 2>/dev/null || true

WORKDIR /app
COPY --from=build /app .

ENV NODE_ENV=production \
    HOME=/paperclip \
    HOST=0.0.0.0 \
    PORT=3100 \
    SERVE_UI=true \
    PAPERCLIP_HOME=/paperclip \
    PAPERCLIP_INSTANCE_ID=default \
    PAPERCLIP_DEPLOYMENT_MODE=authenticated \
    PAPERCLIP_DEPLOYMENT_EXPOSURE=private

RUN mkdir -p /paperclip && chown -R 1000:1000 /paperclip
VOLUME /paperclip
EXPOSE 3100

USER node
CMD ["node", "--import", "./server/node_modules/tsx/dist/loader.mjs", "server/dist/index.js"]
